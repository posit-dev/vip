---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const base = import.meta.env.BASE_URL;
---

<Layout title="Example Report - VIP">
  <Header />

  <div class="page-header">
    <div class="container">
      <h1>Example Validation Report</h1>
      <p>
        A sample report generated by running VIP against Connect and Package Manager in CI.
        This report is rebuilt automatically whenever the website is deployed.
      </p>
      <p class="how-to">
        Generate your own: run <code>vip verify --report results.json</code> to
        save test results, then <code>vip report</code> to render the HTML report.
        For the richer Quarto version, use <code>cd report && quarto render</code>.
      </p>
      <a
        href={`${base}example-report/`}
        class="open-link"
        target="_blank"
        rel="noopener"
      >
        Open in new tab &#8599;
      </a>
    </div>
  </div>

  <main class="report-frame-wrapper">
    <iframe
      src={`${base}example-report/`}
      title="Example VIP validation report"
      class="report-frame"
    ></iframe>
  </main>

  <Footer />
</Layout>

<style>
  .page-header {
    background: white;
    border-bottom: 1px solid var(--posit-border);
    padding: 2rem 1.5rem;
  }

  .page-header h1 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--posit-gray-900);
  }

  .page-header p {
    color: var(--posit-text-muted);
    font-size: 1.0625rem;
    max-width: 640px;
    margin-bottom: 0.75rem;
  }

  .how-to {
    font-size: 0.9375rem;
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .open-link {
    display: inline-flex;
    align-items: center;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--posit-blue);
  }

  .open-link:hover {
    color: var(--posit-link-hover);
  }

  .report-frame-wrapper {
    background: white;
  }

  .report-frame {
    display: block;
    width: 100%;
    height: calc(100vh - 64px - 120px);
    min-height: 600px;
    border: none;
    border-top: 1px solid var(--posit-border);
  }
</style>
