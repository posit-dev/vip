---
const base = import.meta.env.BASE_URL;
const { pathname } = Astro.url;

const links = [
  { href: `${base}`, label: "Home" },
  { href: `${base}getting-started/`, label: "Getting Started" },
  { href: `${base}shiny-app/`, label: "Shiny App" },
  { href: `${base}tests/`, label: "Tests" },
  { href: `${base}feature-matrix/`, label: "Feature Matrix" },
  { href: `${base}report/`, label: "Example Report" },
];

function isActive(href: string): boolean {
  const clean = pathname.replace(/\/$/, "") || "/";
  const target = href.replace(/\/$/, "") || "/";
  return clean === target;
}
---

<header class="header">
  <div class="header-inner">
    <a href={base} class="logo">
      <img src={`${base}logo-posit-light.svg`} width="76" height="19" alt="Posit" />
      <span class="logo-divider"></span>
      <span class="product-name">VIP</span>
    </a>
    <nav>
      {
        links.map((link) => (
          <a
            href={link.href}
            class:list={["nav-link", { active: isActive(link.href) }]}
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="https://github.com/posit-dev/vip"
        class="nav-link github-link"
        target="_blank"
        rel="noopener"
      >
        GitHub
        <svg
          width="16"
          height="16"
          viewBox="0 0 16 16"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47
            7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01
            1.08.58 1.23.82.72 1.21 1.87.87
            2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95
            0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12
            0 0 .67-.21 2.2.82.64-.18 1.32-.27
            2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44
            1.1.16 1.92.08 2.12.51.56.82 1.27.82
            2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54
            1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013
            8.013 0 0016 8c0-4.42-3.58-8-8-8z"
          ></path>
        </svg>
      </a>
    </nav>
  </div>
</header>

<style>
  .header {
    background: white;
    border-bottom: 1px solid var(--posit-border);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    color: var(--posit-gray-900);
    font-weight: 700;
    font-size: 1.125rem;
    text-decoration: none;
  }

  .logo:hover {
    text-decoration: none;
  }

  .logo-divider {
    width: 1px;
    height: 20px;
    background: var(--posit-border);
  }

  .product-name {
    font-family: var(--font-mono);
    letter-spacing: 0.05em;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .nav-link {
    color: var(--posit-gray-900);
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }

  .nav-link:hover {
    color: var(--posit-link-hover);
    background: var(--posit-gray-bg);
    text-decoration: none;
  }

  .nav-link.active {
    color: var(--posit-blue);
    font-weight: 700;
  }

  .github-link {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    margin-left: 0.5rem;
  }
</style>
