# Copy this file to .env and fill in your values.
#
# License keys (required to run the corresponding service)
RSW_LICENSE=
RSC_LICENSE=
RSPM_LICENSE=

# Test credentials (defaults match docker/workbench/startup.sh)
# VIP_TEST_USERNAME=vip_test
# VIP_TEST_PASSWORD=vip_test_password

# Pin image versions for reproducible test environments.
# Leave unset (or remove these lines) to use :latest.
# RSW_VERSION=2024.09.0
# RSC_VERSION=2024.09.0
# RSPM_VERSION=2024.09.0
